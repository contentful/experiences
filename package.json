{
  "name": "@contentful/experiences-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "Nx workspace for the Contentful Experience Orchestration (ExO) SDK suite",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/contentful/experiences.git"
  },
  "bugs": {
    "url": "https://github.com/contentful/experiences/issues"
  },
  "homepage": "https://github.com/contentful/experiences#readme",
  "engines": {
    "node": ">=22.0.0"
  },
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "nx run-many -t build",
    "test": "nx run-many -t test",
    "lint": "nx run-many -t lint",
    "typecheck": "nx run-many -t typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\"",
    "graph": "nx graph",
    "release": "nx release",
    "release:dry": "nx release --dry-run",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@nx/eslint": "^22.7.6",
    "@nx/js": "^22.7.6",
    "@nx/vite": "^22.7.6",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@vitest/coverage-v8": "^1.6.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "nx": "^22.7.6",
    "prettier": "^3.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^5.4.0",
    "vitest": "^3.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}

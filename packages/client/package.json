{
  "name": "@contentful/experiences-client",
  "version": "0.1.0",
  "private": true,
  "description": "Internal delivery client for Contentful Experiences — wraps @contentful/experience-delivery and handles XDN/XPA selection",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
"repository": {
    "type": "git",
    "url": "https://github.com/contentful/experiences.git",
    "directory": "packages/client"
  },
  "dependencies": {
    "@contentful/experience-delivery": "1.0.0-dev.3"
  }
}

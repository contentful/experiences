{
  "name": "adapter-svelte",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/adapter-svelte/src",
  "projectType": "library",
  "tags": ["scope:adapter", "runtime:svelte"],
  "targets": {
    "build": {
      "cache": true,
      "dependsOn": ["^build"],
      "outputs": ["{projectRoot}/dist"],
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/adapter-svelte",
        "command": "svelte-package -i src -o dist"
      }
    },
    "test": {
      "cache": true,
      "dependsOn": ["^build"],
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/adapter-svelte",
        "command": "vitest run"
      }
    }
  }
}

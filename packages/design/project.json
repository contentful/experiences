{
  "name": "design",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/design/src",
  "projectType": "library",
  "tags": ["scope:runtime-neutral", "layer:design"],
  "targets": {
    "build": {
      "cache": true,
      "dependsOn": ["^build"],
      "outputs": ["{projectRoot}/dist"],
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/design",
        "command": "tsup"
      }
    },
    "test": {
      "cache": true,
      "dependsOn": ["^build"],
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/design",
        "command": "vitest run"
      }
    }
  }
}

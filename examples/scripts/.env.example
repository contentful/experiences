# Copy this file to .env (in this directory) and fill in real values.
#
# CMA_TOKEN needs write access to the space + environment above. Create a
# Personal Access Token (CFPAT) at https://app.contentful.com/account/profile/cma_tokens
# — make sure you're in the org that owns the target space.

SPACE_ID=
ENVIRONMENT_ID=master
CMA_TOKEN=
